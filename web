<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Trading Journal — by GlobalCode 2.0</title>
<meta name="description" content="El diario de trading profesional para Forex, Crypto y Prop Firm traders.">
<link href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&family=Google+Sans+Display:wght@400;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html{scroll-behavior:smooth;font-size:16px}
:root{
  --bg:#000;--s1:#0a0a0a;--s2:#111;--s3:#181818;
  --b1:#222;--b2:#2a2a2a;
  --acc:#1a6bff;--acc2:#60a5fa;
  --grn:#34d058;--grn2:#22863a;--red:#f85149;--gld:#e3b341;--pur:#bc8cff;--cyan:#39d353;
  --txt:#e6edf3;--txt2:#8b949e;--txt3:#484f58;
  --font:'Google Sans','Outfit',sans-serif;
  --mono:'JetBrains Mono',monospace;
  --r:16px;
}
body{background:var(--bg);color:var(--txt);font-family:var(--font);overflow-x:hidden;line-height:1.5}

/* ── CURSOR (desktop only) ── */
.cur{position:fixed;width:8px;height:8px;background:var(--grn);border-radius:50%;pointer-events:none;z-index:9999;transition:transform .05s;mix-blend-mode:screen}
.cur-ring{position:fixed;width:30px;height:30px;border:1px solid rgba(52,208,88,.35);border-radius:50%;pointer-events:none;z-index:9998;transition:all .12s ease}
@media(hover:none){.cur,.cur-ring{display:none}}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(0,0,0,.85);backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,.06);height:60px;display:flex;align-items:center;padding:0 24px;gap:16px}
.nav-brand{display:flex;align-items:center;gap:10px;text-decoration:none;flex-shrink:0}
.nav-logo-img{width:36px;height:36px;border-radius:50%;object-fit:cover;display:block}
.nav-brand-text{display:flex;flex-direction:column;line-height:1.1}
.nav-brand-text span:first-child{font-size:13px;font-weight:700;color:var(--txt)}
.nav-brand-text span:last-child{font-size:10px;font-weight:500;background:linear-gradient(90deg,var(--grn),var(--acc2));background-clip:text;-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.nav-links{display:flex;align-items:center;gap:2px;flex:1;margin-left:16px;overflow-x:auto;scrollbar-width:none}
.nav-links::-webkit-scrollbar{display:none}
.nl{font-size:12px;font-weight:500;color:var(--txt2);padding:6px 12px;border-radius:8px;text-decoration:none;cursor:pointer;border:none;background:none;font-family:var(--font);white-space:nowrap;transition:all .15s}
.nl:hover,.nl.active{color:var(--txt);background:rgba(255,255,255,.07)}
.nav-right{display:flex;align-items:center;gap:8px;flex-shrink:0;margin-left:auto}
.lbtn{font-size:11px;font-weight:600;padding:4px 10px;border-radius:14px;border:1px solid var(--b1);background:var(--s1);color:var(--txt2);cursor:pointer;transition:all .15s;font-family:var(--font)}
.lbtn.active,.lbtn:hover{border-color:var(--grn);color:var(--grn);background:rgba(52,208,88,.08)}
.nav-cta{font-size:12px;font-weight:700;padding:8px 18px;border-radius:20px;background:var(--grn);color:#000;text-decoration:none;transition:all .2s;white-space:nowrap;font-family:var(--font)}
.nav-cta:hover{background:#22c55e;box-shadow:0 0 30px rgba(52,208,88,.4);transform:translateY(-1px)}
/* hamburger */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:6px;border:none;background:none}
.hamburger span{width:22px;height:2px;background:var(--txt2);border-radius:2px;transition:all .3s}
@media(max-width:768px){
  .nav-links{display:none}
  .nav-right .lbtn{display:none}
  .hamburger{display:flex}
}
/* mobile menu */
#mobile-menu{display:none;position:fixed;top:60px;left:0;right:0;bottom:0;background:rgba(0,0,0,.97);backdrop-filter:blur(20px);z-index:99;flex-direction:column;padding:24px;gap:4px;overflow-y:auto}
#mobile-menu.open{display:flex}
.mm-link{font-size:18px;font-weight:600;color:var(--txt2);padding:14px 16px;border-radius:12px;cursor:pointer;border:none;background:none;font-family:var(--font);text-align:left;width:100%;transition:all .15s}
.mm-link:hover{background:var(--s2);color:var(--txt)}
.mm-sep{height:1px;background:var(--b1);margin:8px 0}
.mm-cta{margin-top:8px;padding:14px;border-radius:14px;background:var(--grn);color:#000;font-size:16px;font-weight:700;text-align:center;text-decoration:none;display:block}

/* ── HERO ── */
#hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:80px 24px 60px;position:relative}
.hero-badge{display:inline-flex;align-items:center;gap:8px;padding:6px 16px;border-radius:20px;background:rgba(52,208,88,.08);border:1px solid rgba(52,208,88,.2);font-size:11px;font-weight:600;color:var(--grn);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:28px}
.hero-logo{width:80px;height:80px;border-radius:50%;object-fit:cover;margin:0 auto 24px;box-shadow:0 0 40px rgba(52,208,88,.25),0 0 80px rgba(52,208,88,.1)}
.hero h1{font-size:clamp(52px,12vw,120px);font-weight:700;line-height:.92;letter-spacing:-4px;margin-bottom:12px}
.hero h1 .t1{display:block;color:var(--txt)}
.hero h1 .t2{display:block;font-size:clamp(28px,6vw,62px);font-weight:600;letter-spacing:-2px;background:linear-gradient(135deg,var(--grn),var(--acc2),var(--pur));background-clip:text;-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-size:200%;animation:ga 5s ease infinite}
@keyframes ga{0%,100%{background-position:0%}50%{background-position:100%}}
.hero-sub{font-size:clamp(15px,2.5vw,20px);color:var(--txt2);max-width:580px;margin:0 auto 40px;line-height:1.6}
.hero-btns{display:flex;flex-wrap:wrap;gap:12px;justify-content:center;margin-bottom:48px}
.btn-main{padding:14px 32px;border-radius:12px;background:var(--grn);color:#000;font-size:15px;font-weight:700;text-decoration:none;transition:all .25s;font-family:var(--font)}
.btn-main:hover{background:#22c55e;box-shadow:0 0 50px rgba(52,208,88,.4);transform:translateY(-2px)}
.btn-out{padding:14px 32px;border-radius:12px;background:rgba(255,255,255,.04);color:var(--txt);font-size:15px;font-weight:600;text-decoration:none;border:1px solid rgba(255,255,255,.1);transition:all .25s;font-family:var(--font)}
.btn-out:hover{border-color:rgba(255,255,255,.25);background:rgba(255,255,255,.07);transform:translateY(-2px)}

/* TICKER */
.ticker-wrap{width:100%;overflow:hidden;mask-image:linear-gradient(90deg,transparent,black 10%,black 90%,transparent)}
.ticker-inner{display:flex;gap:12px;animation:tick 22s linear infinite;width:max-content}
@keyframes tick{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.tick-item{display:flex;align-items:center;gap:8px;padding:7px 16px;background:var(--s1);border:1px solid var(--b1);border-radius:10px;font-size:12px;font-family:var(--mono);white-space:nowrap}
.tick-dot{width:7px;height:7px;border-radius:50%;background:var(--grn);animation:pd 2s ease infinite;box-shadow:0 0 6px var(--grn);flex-shrink:0}
@keyframes pd{0%,100%{opacity:1}50%{opacity:.3;transform:scale(1.5)}}

/* ── DIVIDER ── */
.gdiv{height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,.08),transparent);margin:0}

/* ── SECTIONS ── */
.sec{padding:100px 24px;position:relative}
.sec-inner{max-width:1100px;margin:0 auto}
.sec-label{font-size:11px;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:var(--grn);margin-bottom:12px;display:flex;align-items:center;gap:10px}
.sec-label::before{content:'';width:20px;height:2px;background:var(--grn);border-radius:2px}
.sec h2{font-size:clamp(32px,5vw,56px);font-weight:700;line-height:1;letter-spacing:-2px;margin-bottom:14px}
.sec-sub{font-size:16px;color:var(--txt2);max-width:580px;margin-bottom:56px;line-height:1.65}

/* ── BENTO GRID (features) ── */
.bento{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
@media(max-width:900px){.bento{grid-template-columns:repeat(2,1fr)}}
@media(max-width:580px){.bento{grid-template-columns:1fr}}
.bcard{background:var(--s1);border:1px solid var(--b1);border-radius:20px;padding:24px;position:relative;overflow:hidden;transition:all .35s;cursor:default}
.bcard:hover{border-color:var(--grn);transform:translateY(-4px);box-shadow:0 20px 50px rgba(0,0,0,.5),0 0 30px rgba(52,208,88,.06)}
.bcard::before{content:'';position:absolute;top:0;left:0;right:0;height:2px}
.bcard-icon{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:24px;margin-bottom:16px}
.bcard h3{font-size:17px;font-weight:700;margin-bottom:8px}
.bcard p{font-size:13px;color:var(--txt2);line-height:1.6}
.btags{display:flex;flex-wrap:wrap;gap:5px;margin-top:12px}
.btag{font-size:10px;font-weight:600;padding:3px 8px;border-radius:5px;background:rgba(52,208,88,.08);border:1px solid rgba(52,208,88,.15);color:var(--grn)}

/* ── SPLIT LAYOUT ── */
.split{display:flex;gap:60px;align-items:center;flex-wrap:wrap}
.split.rev{flex-direction:row-reverse}
.split-t{flex:1;min-width:260px}
.split-t h3{font-size:clamp(26px,4vw,42px);font-weight:700;letter-spacing:-1.5px;line-height:1.05;margin-bottom:14px}
.split-t p{font-size:14.5px;color:var(--txt2);line-height:1.75;margin-bottom:10px}
.split-v{flex:1;min-width:260px;display:flex;justify-content:center}
@media(max-width:700px){.split,.split.rev{flex-direction:column}.split-v{width:100%}}

/* ── DEMO CARDS ── */
.demo{background:var(--s1);border:1px solid var(--b1);border-radius:20px;padding:20px;width:100%;max-width:440px;position:relative;overflow:hidden}
.demo::before{content:'';position:absolute;top:0;left:0;right:0;height:2px}
.demo-lbl{font-size:9px;font-weight:700;color:var(--txt3);letter-spacing:2px;text-transform:uppercase;margin-bottom:12px}

/* Calendar */
.cal-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;font-size:13px;font-weight:700}
.cal-g{display:grid;grid-template-columns:repeat(7,1fr);gap:3px}
.cdh{font-size:8px;font-weight:700;color:var(--txt3);text-align:center;padding:2px}
.cd{aspect-ratio:1;border-radius:7px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:10px;font-weight:700;background:var(--s2);border:1px solid var(--b1);cursor:pointer;transition:all .18s}
.cd:hover{transform:scale(1.15);z-index:2;box-shadow:0 4px 12px rgba(0,0,0,.4)}
.cd.p{background:rgba(14,48,18,.9);border-color:rgba(52,208,88,.3);color:var(--grn)}
.cd.l{background:rgba(50,10,10,.9);border-color:rgba(248,81,73,.3);color:var(--red)}
.cd.t{border-color:var(--acc2);color:var(--acc2)}
.cd.e{background:transparent;border-color:transparent}
.cd-pnl{font-size:6px;margin-top:1px;opacity:.8}

/* KPI */
.kpi-g{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.kpi{background:var(--s2);border:1px solid var(--b1);border-radius:12px;padding:13px}
.kpi-v{font-family:var(--mono);font-size:19px;font-weight:700}
.kpi-l{font-size:9px;color:var(--txt3);text-transform:uppercase;letter-spacing:1px;margin-top:3px}
.pos{color:var(--grn)} .neg{color:var(--red)} .blu{color:var(--acc2)} .gld{color:var(--gld)}

/* Vision donut */
.donut-wrap{position:relative;display:inline-block}
.donut-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;pointer-events:none}

/* Session bars */
.sbar-row{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.sbar-name{font-size:12px;font-weight:700;min-width:82px}
.sbar-track{flex:1;height:20px;background:var(--s2);border-radius:5px;overflow:hidden;border:1px solid var(--b1)}
.sbar-fill{height:100%;border-radius:5px;display:flex;align-items:center;justify-content:flex-end;padding-right:7px;font-size:9px;font-weight:700;transition:width 1.5s cubic-bezier(.4,0,.2,1);width:0}
.sbar-val{font-family:var(--mono);font-size:11px;font-weight:700;min-width:48px;text-align:right}

/* Gauge SVG */
.gauge-wrap{text-align:center}

/* Consistency */
.cons-bar-bg{height:10px;background:rgba(255,255,255,.04);border-radius:20px;overflow:visible;border:1px solid var(--b1);position:relative;margin:10px 0}
.cons-bar-fg{height:100%;border-radius:20px;background:linear-gradient(90deg,var(--acc),var(--acc2),var(--gld));position:relative;transition:width 1.5s cubic-bezier(.4,0,.2,1);width:0}
.cons-bar-fg::after{content:'';position:absolute;right:-9px;top:50%;transform:translateY(-50%);width:20px;height:20px;border-radius:50%;background:#fff;box-shadow:0 0 16px rgba(227,179,65,.9)}
.cons-status{text-align:center;padding:11px;border-radius:10px;font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-top:10px}
.cons-status.nok{background:rgba(248,81,73,.07);border:1px solid rgba(248,81,73,.2);color:var(--red)}

/* Eco events */
.eco-item{display:flex;align-items:center;gap:9px;padding:9px 12px;background:var(--s2);border:1px solid var(--b1);border-radius:10px;margin-bottom:7px;font-size:12px;transition:all .2s;cursor:pointer}
.eco-item:hover{border-color:rgba(255,255,255,.15);transform:translateX(4px)}
.eco-time{font-family:var(--mono);color:var(--txt3);min-width:44px}
.eco-name{flex:1;font-weight:600}
.eco-imp{padding:2px 7px;border-radius:5px;font-size:9px;font-weight:700;letter-spacing:.5px}
.eco-imp.hi{background:rgba(248,81,73,.12);color:var(--red);border:1px solid rgba(248,81,73,.2)}
.eco-imp.md{background:rgba(227,179,65,.1);color:var(--gld);border:1px solid rgba(227,179,65,.18)}
.eco-imp.lo{background:rgba(52,208,88,.08);color:var(--grn);border:1px solid rgba(52,208,88,.15)}

/* History */
.hist-item{display:flex;align-items:center;gap:10px;padding:11px 14px;background:var(--s2);border:1px solid var(--b1);border-radius:12px;margin-bottom:7px;cursor:pointer;transition:all .2s;position:relative;padding-left:18px}
.hist-item::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;border-radius:3px 0 0 3px}
.hist-item.tp::before{background:var(--grn)}
.hist-item.sl::before{background:var(--red)}
.hist-item.be::before{background:var(--acc2)}
.hist-item:hover{transform:translateX(4px);border-color:var(--b2)}
.hist-asset{font-weight:800;min-width:58px;font-size:13px}
.hbadge{font-size:9px;font-weight:700;padding:2px 7px;border-radius:5px}
.hbadge.tp{background:rgba(52,208,88,.1);color:var(--grn);border:1px solid rgba(52,208,88,.2)}
.hbadge.sl{background:rgba(248,81,73,.1);color:var(--red);border:1px solid rgba(248,81,73,.2)}
.hbadge.be{background:rgba(96,165,250,.1);color:var(--acc2);border:1px solid rgba(96,165,250,.2)}
.hdir{font-size:9px;font-weight:700;padding:2px 6px;border-radius:4px}
.hdir.buy{background:rgba(52,208,88,.1);color:var(--grn)}
.hdir.sell{background:rgba(248,81,73,.1);color:var(--red)}
.hist-pnl{margin-left:auto;font-family:var(--mono);font-size:13px;font-weight:700}
.hist-date{font-size:10px;color:var(--txt3);font-family:var(--mono);margin-left:4px}

/* ── PRICING ── */
.price-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
@media(max-width:700px){.price-grid{grid-template-columns:1fr}}
.pc{background:var(--s1);border:1px solid var(--b1);border-radius:20px;padding:28px;text-align:center;transition:all .3s;position:relative;overflow:hidden}
.pc:hover{transform:translateY(-5px);box-shadow:0 24px 50px rgba(0,0,0,.5)}
.pc.best{border-color:rgba(52,208,88,.4);background:linear-gradient(180deg,rgba(52,208,88,.05),var(--s1))}
.pc.best::before{content:'⭐ MEJOR PRECIO';position:absolute;top:14px;left:50%;transform:translateX(-50%);background:var(--grn);color:#000;font-size:9px;font-weight:800;padding:3px 14px;border-radius:20px;white-space:nowrap;font-family:var(--font)}
.pc-icon{font-size:28px;margin-bottom:10px;margin-top:12px}
.pc-name{font-size:16px;font-weight:700;margin-bottom:6px}
.pc-price{font-size:clamp(36px,5vw,50px);font-weight:700;font-family:var(--mono);line-height:1}
.pc-per{font-size:12px;color:var(--txt3);margin:5px 0 16px}
.pc-desc{font-size:13px;color:var(--txt2);margin-bottom:20px;line-height:1.5}
.pc-btn{display:block;padding:12px;border-radius:10px;font-size:13px;font-weight:700;text-decoration:none;font-family:var(--font);cursor:pointer;border:none;width:100%;transition:all .2s}
.pc-btn.g{background:var(--grn);color:#000}
.pc-btn.g:hover{background:#22c55e;box-shadow:0 0 30px rgba(52,208,88,.3)}
.pc-btn.o{background:transparent;color:var(--acc2);border:1px solid rgba(96,165,250,.25)}

/* ── CTA BANNER ── */
.cta-banner{background:linear-gradient(135deg,rgba(52,208,88,.08),rgba(26,107,255,.06));border:1px solid rgba(52,208,88,.15);border-radius:24px;padding:64px 40px;text-align:center;position:relative;overflow:hidden;margin-top:64px}
.cta-banner h2{font-size:clamp(28px,5vw,52px);font-weight:700;letter-spacing:-2px;margin-bottom:14px}
.cta-banner p{font-size:16px;color:var(--txt2);margin-bottom:32px;max-width:500px;margin-left:auto;margin-right:auto}

/* ── FOOTER ── */
footer{background:var(--s1);border-top:1px solid var(--b1);padding:60px 24px 40px;text-align:center}
.footer-logo{display:flex;align-items:center;justify-content:center;gap:12px;margin-bottom:12px}
.footer-links{display:flex;justify-content:center;gap:20px;flex-wrap:wrap;margin:18px 0;font-size:13px}
.footer-links a{color:var(--txt2);text-decoration:none;transition:color .2s}
.footer-links a:hover{color:var(--grn)}

/* ── ANIMATIONS ── */
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
@keyframes bar-grow{from{width:0}to{width:var(--w)}}
@keyframes slide-in{from{opacity:0;transform:translateX(-10px)}to{opacity:1;transform:translateX(0)}}
@keyframes kpi-up{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@keyframes candle-up{from{height:0;transform-origin:bottom}to{height:var(--h)}}
.float{animation:float 4s ease-in-out infinite}
.atrade{animation:slide-in .4s ease var(--d,.1s) both}
.akpi{animation:kpi-up .5s ease var(--d,.1s) both}
.acandle{animation:candle-up .9s cubic-bezier(.4,0,.2,1) var(--d,.1s) both}

/* ── REVEAL ── */
.rv{opacity:0;transform:translateY(28px);transition:all .7s cubic-bezier(.4,0,.2,1)}
.rv.vis{opacity:1;transform:translateY(0)}
.rvl{opacity:0;transform:translateX(-28px);transition:all .7s cubic-bezier(.4,0,.2,1)}
.rvl.vis{opacity:1;transform:translateX(0)}
.rvr{opacity:0;transform:translateX(28px);transition:all .7s cubic-bezier(.4,0,.2,1)}
.rvr.vis{opacity:1;transform:translateX(0)}

/* ── UTILS ── */
.pill-grn{display:inline-flex;align-items:center;gap:6px;padding:4px 12px;border-radius:16px;font-size:12px;font-weight:600;background:rgba(52,208,88,.08);border:1px solid rgba(52,208,88,.18);color:var(--grn);margin-bottom:14px}
</style>
</head>
<body>

<div class="cur" id="cur"></div>
<div class="cur-ring" id="curring"></div>

<!-- ── NAV ── -->
<nav id="topnav">
  <a class="nav-brand" href="#hero">
    <img class="nav-logo-img" src="data:image/png;base64," alt="Trading Journal">
    <div class="nav-brand-text">
      <span>Trading Journal</span>
      <span>by GlobalCode 2.0</span>
    </div>
  </a>
  <div class="nav-links">
    <button class="nl active" onclick="goTo('#hero')" data-i18n="nav_home">Inicio</button>
    <button class="nl" onclick="goTo('#sec-feat')" data-i18n="nav_feat">Funciones</button>
    <button class="nl" onclick="goTo('#sec-cal')" data-i18n="nav_cal">Calendario</button>
    <button class="nl" onclick="goTo('#sec-stats')" data-i18n="nav_stats">Stats</button>
