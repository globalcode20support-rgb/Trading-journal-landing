/* balance chart */
function drawChart(){
  const c=document.getElementById('balance-chart');if(!c)return;
  const ctx=c.getContext('2d'),W=c.parentElement.offsetWidth-40||360,H=80;
  c.width=W*2;c.height=H*2;c.style.width=W+'px';c.style.height=H+'px';ctx.scale(2,2);
  const d=[0,200,80,420,850,620,1100,950,1800,1500,2400,2100,3000,2800,3900,4600,5200,4800,6100,7200,7800,7500,8597];
  const mn=Math.min(...d),mx=Math.max(...d),r=mx-mn||1;
  const p={t:6,b:6,l:4,r:4},pw=W-p.l-p.r,ph=H-p.t-p.b;
  const pts=d.map((v,i)=>({x:p.l+i/(d.length-1)*pw,y:p.t+ph-(v-mn)/r*ph}));
  const g=ctx.createLinearGradient(0,p.t,0,p.t+ph);
  g.addColorStop(0,'rgba(52,208,88,.2)');g.addColorStop(1,'rgba(52,208,88,.01)');
  ctx.beginPath();ctx.moveTo(pts[0].x,p.t+ph);pts.forEach(pt=>ctx.lineTo(pt.x,pt.y));ctx.lineTo(pts[pts.length-1].x,p.t+ph);ctx.closePath();ctx.fillStyle=g;ctx.fill();
  const lg=ctx.createLinearGradient(0,0,W,0);lg.addColorStop(0,'#1a6bff');lg.addColorStop(1,'#34d058');
  ctx.beginPath();pts.forEach((pt,i)=>i===0?ctx.moveTo(pt.x,pt.y):ctx.lineTo(pt.x,pt.y));ctx.strokeStyle=lg;ctx.lineWidth=2;ctx.lineJoin='round';ctx.stroke();
  const ep=pts[pts.length-1];
  ctx.beginPath();ctx.arc(ep.x,ep.y,4,0,Math.PI*2);ctx.fillStyle='rgba(52,208,88,.25)';ctx.fill();
  ctx.beginPath();ctx.arc(ep.x,ep.y,2.5,0,Math.PI*2);ctx.fillStyle='#34d058';ctx.fill();
  ctx.font='bold 9px JetBrains Mono';ctx.fillStyle='#34d058';ctx.textAlign='left';
  ctx.fillText('+$8,597',ep.x+6,ep.y<p.t+ph*0.5?ep.y+12:ep.y-6);
}
setTimeout(drawChart,200);window.addEventListener('resize',drawChart);

