    const a=Math.PI+Math.PI*ga,cx=110,cy=115,r=90;
    const n=document.getElementById('gneedle');
    if(n){n.setAttribute('x2',Math.round(cx+(r-15)*Math.cos(a)));n.setAttribute('y2',Math.round(cy+(r-15)*Math.sin(a)));}
    const p=document.getElementById('gpct');if(p)p.textContent=Math.round(ga*100)+'%';
    requestAnimationFrame(animGauge);
  }
}
setTimeout(animGauge,500);

/* session bars + cons bar — animate when visible */
function animSess(){document.querySelectorAll('.sbar-fill').forEach(el=>{el.style.width=el.getAttribute('data-w')+'%';});}
function animCons(){const b=document.getElementById('cons-bar');if(b)b.style.width='56%';}
const obsOpts={threshold:.3};
const sessObs=new IntersectionObserver(e=>{if(e[0].isIntersecting){animSess();sessObs.disconnect();}},obsOpts);
const consObs=new IntersectionObserver(e=>{if(e[0].isIntersecting){animCons();consObs.disconnect();}},obsOpts);
const sessEl=document.getElementById('sess-demo');if(sessEl)sessObs.observe(sessEl);
const consEl=document.getElementById('cons-bar');if(consEl)consObs.observe(consEl);

/* reveal on scroll */
const rvEls=document.querySelectorAll('.rv,.rvl,.rvr');
const rvObs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis');});},{threshold:.07});
rvEls.forEach(r=>rvObs.observe(r));
</script>
